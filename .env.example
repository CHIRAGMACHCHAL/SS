# SS Mini AGI - Environment Configuration Template
# Copy this file to .env and fill in your actual values

# ========================================
# DATABASE CONFIGURATION
# ========================================
# PostgreSQL connection string for conversation memory
DATABASE_URL=postgresql://user:password@localhost:5432/vedic_agi

# Redis connection string for caching
REDIS_URL=redis://localhost:6379/0

# ========================================
# VECTOR DATABASE (Qdrant)
# ========================================
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your_qdrant_api_key_here

# ========================================
# LLM CONFIGURATION
# ========================================
# OpenAI API (if using GPT models)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API (if using Claude models)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Hugging Face (for embeddings and open models)
HUGGINGFACE_TOKEN=your_huggingface_token_here

# Local LLM path (if using local models)
LOCAL_MODEL_PATH=/path/to/your/local/model

# ========================================
# PAYMENT GATEWAYS
# ========================================
# Stripe (for international payments)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key

# Razorpay (for Indian payments)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ========================================
# AUTHENTICATION
# ========================================
# JWT secret for token signing
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# JWT expiration (in seconds)
JWT_EXPIRATION=86400

# ========================================
# API CONFIGURATION
# ========================================
# API server settings
API_HOST=0.0.0.0
API_PORT=8080

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Rate limiting
RATE_LIMIT_CALLS=10
RATE_LIMIT_PERIOD=60

# ========================================
# STORAGE
# ========================================
# AWS S3 (for file storage)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=vedic-agi-files
AWS_REGION=us-east-1

# ========================================
# MONITORING & LOGGING
# ========================================
# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Sentry (error tracking)
SENTRY_DSN=your_sentry_dsn_here

# ========================================
# FEATURE FLAGS
# ========================================
# Enable/disable specific features
ENABLE_AGENCY=false
ENABLE_WEB_SEARCH=true
ENABLE_CODE_EXECUTION=false

# ========================================
# TIER SETTINGS
# ========================================
# Founder email for Jarvis tier
JARVIS_EMAIL=chirag@example.com

# Default tier for new users
DEFAULT_TIER=free

# ========================================
# SCRIPTURE PATHS
# ========================================
# Path to scripture PDFs
SCRIPTURE_PATH=./data/scriptures/public
JARVIS_SCRIPTURE_PATH=./data/scriptures/private

# ========================================
# EMBEDDING MODEL
# ========================================
# Model for generating embeddings
EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2

# Embedding dimension
EMBEDDING_DIM=768

# ========================================
# DEVELOPMENT
# ========================================
# Enable debug mode
DEBUG=false

# Enable trace logging (verbose)
TRACE_LOGGING=false

# Disable authentication (for local dev only)
DISABLE_AUTH=false
